{
  "resource": {
    "konnect_gateway_service": {
      "httpbin_api_via_kong_1": {
        "name": "httpbin-api-via-kong",
        "protocol": "https",
        "host": "httpbin.org",
        "port": 443,
        "path": "/",
        "control_plane_id": "${var.control_plane_id}"
      }
    },
    "konnect_gateway_route": {
      "httpbin_api_via_kong_getanything_1": {
        "name": "httpbin-api-via-kong_getanything",
        "paths": [
          "~/anything$"
        ],
        "methods": [
          "GET"
        ],
        "service": {
          "id": "${konnect_gateway_service.httpbin_api_via_kong_1.id}"
        },
        "control_plane_id": "${var.control_plane_id}"
      }
    },
    "konnect_gateway_plugin_key_auth": {
      "httpbin_api_via_kong_1_keyauth": {
        "control_plane_id": "${var.control_plane_id}",
        "service": {
          "id": "${konnect_gateway_service.httpbin_api_via_kong_1.id}"
        },
        "config": {
          "key_names": [
            "apikey"
          ]
        }
      }
    },
    "konnect_gateway_plugin_rate_limiting": {
      "httpbin_api_via_kong_1_ratelimit": {
        "control_plane_id": "${var.control_plane_id}",
        "service": {
          "id": "${konnect_gateway_service.httpbin_api_via_kong_1.id}"
        },
        "config": {
          "minute": 5,
          "policy": "local"
        }
      }
    }
  }
}